<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Final Rankings</title>
    <style>
        table {
            width: 50%;
            margin: 20px auto;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            text-align: center;
            border: 1px solid #ddd;
        }
        th {
            background-color: #f2f2f2;
        }
        a {
            display: block;
            text-align: center;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <h2>Final Rankings</h2>
    <table>
        <tr>
            <th>Rank</th>
            <th>Player Name</th>
            <th>Score</th>
        </tr>
        <% if (rankings && rankings.length > 0) { %>
            <% rankings.forEach((player, index) => { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td><%= player.username %></td>
                    <td><%= player.score %></td>
                </tr>
            <% }); %>
        <% } else { %>
            <tr>
                <td colspan="3">No rankings available.</td>
            </tr>
        <% } %>
    </table>
    <a href="/coordinator/enrolled_players?tournament_id=<%= tournamentId %>">Back to Players</a>
</body>
</html>