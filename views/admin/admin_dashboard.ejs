<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - ChessHive</title>
    <link rel="stylesheet" href="/css/primary_styles.css">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }
        .dashboard {
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
        }
        .sidebar h2 {
            font-size: 1.5em;
            margin-bottom: 20px;
            text-align: center;
        }
        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
            transition: background-color 0.3s;
        }
        .sidebar a:hover {
            background-color: #34495e;
        }
        .content {
            flex-grow: 1;
            padding: 20px;
            background-color: #ecf0f1;
            position: relative;
        }
        .greeting {
            font-size: 1.8em;
            color: #2c3e50;
            margin-bottom: 20px;
        }
        .logout-box {
            position: absolute;
            top: 20px;
            right: 20px;
        }
        .logout-box button {
            padding: 10px 20px;
            background-color: #e74c3c;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        .logout-box button:hover {
            background-color: #c0392b;
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <!-- Sidebar (Included Partial) -->
        <%- include('../partials/dashboards/adminpartials/dashboardnavbar') %>

        <!-- Main Content -->
        <div class="content">
            <% if (typeof adminName !== "undefined" && adminName) { %>
                <div class="greeting">Welcome, <%= adminName %>!</div>
            <% } else { %>
                <div class="greeting">Welcome, Admin!</div>
            <% } %>
            <div class="logout-box">
                <button onclick="redirectToLogin()">Log Out</button>
            </div>
            <div class="contact-messages">
                <h2>Contact Messages</h2>
                <% if (typeof contactMessages !== 'undefined' && contactMessages.length > 0) { %>
                    <ul>
                        <% contactMessages.forEach(message => { %>
                            <li>
                                <strong>Name:</strong> <%= message.name %><br>
                                <strong>Message:</strong> <%= message.message %><br>
                            </li>
                        <% }); %>
                    </ul>
                <% } else { %>
                    <p>No messages available.</p>
                <% } %>
            </div>
        </div>


        
    </div>

    <script>
        function redirectToLogin() {
            window.location.href = "/login";
        }
    </script>
</body>
</html>