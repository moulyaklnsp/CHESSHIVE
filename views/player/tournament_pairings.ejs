<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pairings - <%= tournament.name %></title>
    <link rel="stylesheet" href="/css/primary_styles.css">
</head>
<body>
    <div class="container2">
        <h1>Pairings for <%= tournament.name %></h1>
        <% if (pairings.length > 0) { %>
            <table border="1">
                <thead>
                    <tr>
                        <th>Round</th>
                        <th>Player 1</th>
                        <th>Player 2</th>
                    </tr>
                </thead>
                <tbody>
                    <% pairings.forEach(pairing => { %>
                        <tr>
                            <td><%= pairing.round %></td>
                            <td><%= pairing.player1 %></td>
                            <td><%= pairing.player2 %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p>No pairings available yet.</p>
        <% } %>
        <div class="back-container">
            <a href="/player/player_tournament" class="back">Back to Tournaments</a>
        </div>
    </div>
</body>
</html>
