<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Subscription - ChessHive</title>
    <link rel="stylesheet" href="/css/primary_styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <h2 class="black-h2">Manage Subscription</h2>
         <!-- Success/Error Messages -->
         <% if (successMessage) { %>
            <p style="color: green;"><%= successMessage %></p>
        <% } %>
        <% if (errorMessage) { %>
            <p style="color: red;"><%= errorMessage %></p>
        <% } %>
        
        <!-- Wallet Section -->
        <div class="table-div">
            <h3>Wallet Balance: &#8377;<span id="walletBalance"><%= walletBalance %></span></h3>
            <form action="/player/add-funds" method="POST">
                <input type="number" name="amount" placeholder="Enter amount" min="1" required>
                <input type="hidden" name="redirectTo" value="/player/subscription">
                <button type="submit">Add Funds</button>
            </form>
        </div>

        <!-- Subscription Plans -->
        <div class="form-container">
            <div class="table-div">
                <h3>Basic Plan</h3>
                <p>Access to tournaments and a discount of 10% on store products.</p>
                <p>Price: &#8377;15/month</p>
                <form action="/player/subscribe" method="POST">
                    <input type="hidden" name="plan" value="Basic">
                    <input type="hidden" name="price" value="15">
                    <button type="submit">Subscribe</button>
                </form>
            </div>
            <div class="table-div">
                <h3>Premium Plan</h3>
                <p> Access to tournaments and a discount of 20% on store products.</p>
                <p>Price: &#8377;30/month</p>
                <form action="/player/subscribe" method="POST">
                    <input type="hidden" name="plan" value="Premium">
                    <input type="hidden" name="price" value="30">
                    <button type="submit">Subscribe</button>
                </form>
            </div>
        </div>

        <!-- Current Subscription -->
        <% if (currentSubscription) { %>
            <div class="table-div">
                <h3>Current Subscription</h3>
                <h4>Plan: <%= currentSubscription.plan %></h4>
                <h4>Start Date: <%= currentSubscription.start_date %></h4>
                <h4>Price: &#8377;<%= currentSubscription.price %>/month</h4>
            </div>
        <% } %>

        <div class="form-container back-container">
            <a href="/player/player_dashboard" class="back">Back to Dashboard</a>
        </div>
    </div>
</body>
</html>